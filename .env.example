# Copy this to .env and fill in your keys — never commit .env to GitHub

# From firecrawl.dev → Dashboard → API Keys
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxx

# From console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# From elevenlabs.io → Agents → your agent → Settings tab (bottom)
ELEVENLABS_AGENT_ID=xxxxxxxxxxxxxxxxxxxxxxxx

# From elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxx

PORT=3000
